{% extends 'base.html.twig' %}

{% block title %}Choisir les thèmes{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Thématiques — Vigie BC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<link href="/css/Style_woah.css" rel="stylesheet">
</head>
<body>
<div class="onboarding" data-onboarding-step>

  <div class="onboarding__top">
    <a href="/" class="brand"><span class="brand__mark"></span> Vigie BC</a>
    <a href="{{ path('dashboard') }}" class="onboarding__skip-all">Passer la configuration →</a>
  </div>

  {% include 'onboarding/_steps.html.twig' with {'active': 1} %}

  <div class="onboarding__body">
    <div class="wizard-card">
      <div class="eyebrow">Étape 1 sur 5</div>
      <h2>Quels types de BC vous intéressent ?</h2>
      <p>Sélectionnez une ou plusieurs thématiques. Vous pourrez les modifier plus tard depuis votre profil.</p>

      <form method="post" action="{{ path('app_choose_topics') }}">
        <div class="option-grid" data-selectable>
          {% for topic in topics %}
            <label class="option-pill">
              <input type="checkbox" name="topics[]" value="{{ topic.id }}"{% if topic.id in selectedTopics %}checked{% endif %}>
              <span class="check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>
              {{ topic.name }}
            </label>
          {% else %}
            <p style="font-size:13.5px;color:var(--ink-400);">Aucune thématique disponible pour le moment.</p>
          {% endfor %}
        </div>
        <span class="wizard-selected-count" data-selected-count>{{ selectedTopics|length }} sélections</span>

        <div class="wizard-footer">
          <button type="submit" name="skip" value="1" class="btn btn-ghost">Passer cette étape</button>
          <button type="submit" class="btn btn-primary">Continuer</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script src="/js/app_woah.js"></script>
</body>
</html>

{% endblock %}