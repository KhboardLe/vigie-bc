{% extends 'base.html.twig' %}

{% block title %}Mes BC{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mes BC — Vigie BC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<link href="/css/Styles_more.css" rel="stylesheet">
</head>
<body>
<div class="app">

  <aside class="sidebar">
    <a href="{{ path('dashboard') }}" class="brand"><span class="brand__mark"></span> Vigie BC</a>
    <div class="sidebar__section">Navigation</div>
    <nav class="sidebar__nav">
      <a href="{{ path('dashboard') }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
        Tableau de bord
      </a>
      <a href="{{ path('app_bc_list') }}" class="active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        BC en cours
      </a>
      <a href="{{ path('app_profile') }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0116 0v1"/></svg>
        Profil
      </a>
    </nav>
    <div class="sidebar__spacer"></div>
    <a href="{{ path('app_logout') }}" class="logout-link" style="display:flex;align-items:center;gap:12px;padding:11px 12px;font-size:13.5px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg>
      Déconnexion
    </a>
  </aside>

  <div class="main">
    <div class="topbar">
      <div>
        <h1>Mes Bons de Commande</h1>
        <div class="topbar__sub">{{ bcs|length }} résultat{{ bcs|length > 1 ? 's' : '' }} correspondant à vos critères</div>
      </div>
      <div class="topbar__actions">
        <button class="icon-btn" title="Notifications"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 7l-10 7L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg><span class="badge"></span></button>
        <a href="{{ path('app_choose_topics') }}" class="btn btn-primary btn-sm">+ Filtre</a>
      </div>
    </div>

    <div class="page">
      <div class="card reveal">
        <div class="card__head">
          <h3>Bons de commande</h3>
          <span class="topbar__sub" data-bc-count>{{ bcs|length }}</span>
        </div>

        {% if bcs is empty %}
          <div class="empty-state">
            <h3>🎉 Aucun BC ne correspond à vos critères</h3>
            <p>Ajustez vos filtres ou revenez après le prochain scan.</p>
          </div>
        {% else %}

          

          <div class="table-wrap">
            <table data-bc-table>
              <thead>
                <tr>
                  <th data-sort="reference">Référence</th>
                  <th data-sort="category">Catégorie</th>
                  <th data-sort="nature">Nature</th>
                  <th data-sort="lieu">Ville</th>
                  <th data-sort="date_limite">Date limite</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for bc in bcs %}
                 
                  <tr
                    <tr
    data-reference="{{ bc.reference }}"
   
    data-category="{{ bc.category }}"
    data-nature="{{ bc.nature }}"
    data-lieu="{{ bc.lieu }}"
    data-date_limite="{{ bc.date_limite }}"
    data-search="{{ bc.reference }} {{ bc.objet }} {{ bc.category }} {{ bc.nature }} {{ bc.lieu }}"
>
                  >
                    <td>
    <a
        class="ref-code"
        href="{{ bc.detail_url }}"
        target="_blank">
        {{ bc.reference }}
    </a>
</td>

{% if bc.objet|length > 120 %}
...
{% endif %}</td>
                    <td>
                      <div class="match-tags">
                        <span class="match-tag">{{ bc.category }}</span>
                      </div>
                    </td>
                    <td>{{ bc.nature }}</td>
                    <td>{{ bc.lieu }}</td>
                    <td>{{ bc.date_limite }}</td>
                    <td>
    <a href="{{ bc.detail_url }}"
       target="_blank"
       class="btn btn-primary btn-sm">
        Voir le BC
    </a>
</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

       <div class="pagination">

    <a>«</a>

    <div class="pagination-pages">

        {% for i in 1..totalPages %}

            <a
                href="{{ path('app_bc_list',{page:i}) }}"
                class="{% if i==page %}active{% endif %}">
                {{ i }}
            </a>

        {% endfor %}

    </div>

    <a>»</a>

</div>

        {% endif %}
      </div>
    </div>
  </div>
</div>
<script src="/js/Scripts_more.js"></script>
</body>
</html>
{% endblock %}