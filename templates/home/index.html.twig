   href="{{ path('home') }}">
    Vigie BC
</a>
                <a class="btn btn-primary"
href="{{ path('app_register') }}">
    Start
</a>

<a class="btn btn-outline-primary ms-2"
href="{{ path('app_login') }}">
    Login
</a>
            </div>
        </nav>
        <!-- Masthead-->
        <header class="masthead">
            <div class="container position-relative">
