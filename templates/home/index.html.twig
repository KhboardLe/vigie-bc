    </head>
    <body>
        <!-- Navigation-->
        <nav class="navbar navbar-light bg-light static-top">
            <div class="container">
                <a href="/" class="brand"><span class="brand__mark"></span> Vigie BC</a>
                
            </div>
        </nav>
        <!-- Masthead-->
        <header class="masthead">
            <div class="container position-relative">
                <div class="row justify-content-center">
                    <div class="col-xl-6">
                        <div class="text-center text-white">
                            <!-- Page heading-->
                            <h1 class="mb-5">La veille intelligente des Bons de Commande publics.</h1>
                            <!-- Signup form-->
                            <!-- * * * * * * * * * * * * * * *-->
