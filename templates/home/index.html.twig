<div class="mt-5">

<a class="btn btn-primary btn-lg"

href="{{ path('app_register') }}">

Créer un compte

</a>

<a class="btn btn-outline-light btn-lg ms-3"

href="{{ path('app_login') }}">

Se connecter

</a>

</div>

                        </div>
                    </div>
                </div>
            </div>
        </header>
        <!-- Icons Grid-->
        <section class="features-icons bg-light text-center" id="features">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4">
                        <div class="features-icons-item mx-auto mb-5 mb-lg-0 mb-lg-3">
                            <div class="features-icons-icon d-flex"><i class="bi-search m-auto text-primary"></i></div>
                            <h3>Surveillance Automatique</h3>
                            <p class="lead mb-0">Vigie BC analyse automatiquement le portail des marchés publics pour vous, afin que vous n'ayez plus à rechercher manuellement les nouveaux Bons de Commande.</p>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="features-icons-item mx-auto mb-5 mb-lg-0 mb-lg-3">
                            <div class="features-icons-icon d-flex"><i class="bi-funnel m-auto text-primary"></i></div>
                            <h3>Alertes Personnalisées</h3>
                            <p class="lead mb-0">Définissez une seule fois vos catégories, mots-clés et villes, puis chaque nouveau Bon de Commande est automatiquement comparé à votre profil.</p>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="features-icons-item mx-auto mb-0 mb-lg-3">
                            <div class="features-icons-icon d-flex"><i class="bi-envelope m-auto text-primary"></i></div>
                            <h3>Notifications par E-mail</h3>
                            <p class="lead mb-0">Recevez un e-mail dès qu'un Bon de Commande correspondant à vos critères est publié, sans avoir à consulter ou actualiser le portail manuellement.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Image Showcases-->
        <section class="showcase">
            <div class="container-fluid p-0">
                <div class="row g-0">
                    <div class="col-lg-6 order-lg-2 text-white showcase-img" style="background-image: url('assets/img/bg-showcase-1.jpg')"></div>
                    <div class="col-lg-6 order-lg-1 my-auto showcase-text">
                        <h2>Un tableau de bord clair</h2>
                        <p class="lead mb-0">Consultez les derniers Bons de Commande, vos alertes récentes et les statistiques de votre activité depuis une seule interface.</p>
                    </div>
                </div>
                <div class="row g-0">
                    <div class="col-lg-6 text-white showcase-img" style="background-image: url('assets/img/bg-showcase-2.jpg')"></div>
                    <div class="col-lg-6 my-auto showcase-text">
                        <h2>Des alertes adaptées à votre activité</h2>
                        <p class="lead mb-0">Choisissez les catégories, natures, villes et mots-clés qui correspondent à votre domaine d'activité. Vigie BC détecte automatiquement les Bons de Commande compatibles et les transforme en alertes directement dans votre tableau de bord.</p>
                    </div>
                </div>
                <div class="row g-0">
                    <div class="col-lg-6 order-lg-2 text-white showcase-img" style="background-image: url('assets/img/bg-showcase-3.jpg')"></div>
                    <div class="col-lg-6 order-lg-1 my-auto showcase-text">
                        <h2>Ne surveillez plus le portail manuellement</h2>
                        <p class="lead mb-0">Un système de collecte automatisé analyse en continu le portail des marchés publics afin de détecter les nouvelles opportunités. Vous pouvez ainsi vous concentrer sur la préparation de vos offres pendant que Vigie BC effectue la veille pour vous.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Call to Action-->
    
        <!-- Footer-->
