                            <li class="list-inline-item">⋅</li>
                            <li class="list-inline-item"><a href="{{ path('app_login') }}">Login</a></li>
                            <li class="list-inline-item">⋅</li>
                            <li class="list-inline-item"><a href="{{ path('app_register') }}">Register</a></li>
