{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}

<!DOCTYPE html>
<html lang="fr">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Mot de passe oublié — Vigie BC</title>

<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<link href="/css/Styles_more.css" rel="stylesheet">

</head>

<body>

<div class="app">

<div class="main" style="margin:auto;max-width:700px;">

<div class="topbar">

<div>

<h1>Mot de passe oublié</h1>

<div class="topbar__sub">

Nous vous enverrons un mot de passe temporaire par email.

</div>

</div>

</div>

<div class="page">

{% for message in app.flashes('success') %}
    <div class="alert alert-success">
        {{ message }}
    </div>
{% endfor %}

<div class="card reveal" style="max-width:650px;margin:auto;">

<div class="card__head">

<h3>Réinitialisation du mot de passe</h3>

</div>

<p style="margin-bottom:20px;font-size:14px;color:var(--ink-400);">

Entrez l'adresse email utilisée pour votre compte Vigie BC.
Un mot de passe temporaire sera envoyé à cette adresse.
Vous pourrez ensuite vous connecter et modifier votre mot de passe depuis votre profil.

</p>

<form method="post"
      action="{{ path('app_send_temp_password') }}">

<div class="field">

<label for="email">

Adresse email

</label>

<input
    id="email"
    type="email"
    name="email"
    placeholder="nom@exemple.com"
    required>

</div>

<div style="display:flex;justify-content:space-between;align-items:center;margin-top:28px;">

<a
href="{{ path('app_login') }}"
class="btn btn-outline">

← Retour à la connexion

</a>

<button
type="submit"
class="btn btn-primary">

Envoyer un mot de passe temporaire

</button>

</div>

</form>

</div>

</div>

</div>

</div>

<script src="/js/Scripts_more.js"></script>

</body>
</html>

{% endblock %}