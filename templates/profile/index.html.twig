{% extends 'base.html.twig' %}

{% block title %}Hello ProfileController!{% endblock %}
{% block body %}
{% if error %}
    <div class="alert alert-danger">
        {{ error }}
    </div>
{% endif %}

{% if success %}
    <div class="alert alert-success">
        {{ success }}
    </div>
{% endif %}



<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profil — Vigie BC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<link href="/css/Styles_more.css" rel="stylesheet">
</head>
<body>
<div class="app">

  <aside class="sidebar">
    <a href="/" class="brand"><span class="brand__mark"></span> Vigie BC</a>
    <div class="sidebar__section">Navigation</div>
    <nav class="sidebar__nav">
      <a href="/dashboard">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
        Tableau de bord
      </a>
      <a href="{{ path('app_bc_list') }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        BC en cours
      </a>
      
      <a href="{{ path('app_profile') }}" class="active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0116 0v1"/></svg>
        Profil
      </a>
    </nav>
    <div class="sidebar__spacer"></div>
    <div class="sidebar__user">
      <div class="avatar">{{ initials }}</div>
      <div><b>{{ user.full_name }}</b><span>{{ user.email }}</span></div>
    </div>
    <a href="/logout" class="logout-link" style="display:flex;align-items:center;gap:12px;padding:11px 12px;font-size:13.5px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg>
      Déconnexion
    </a>
  </aside>

  <div class="main">
    <div class="topbar">
      <div>
        <h1>Profil</h1>
        <div class="topbar__sub">Gérez vos informations personnelles et votre compte.</div>
      </div>
    </div>

    <div class="page">

{% if success %}
<div class="alert alert-success">
    {{ success }}
</div>
{% endif %}

      <div class="card reveal" style="max-width:680px;">
        <div class="profile-head">
          <div class="avatar-lg">{{ initials }}</div>
          <div>
            <h3 style="margin-bottom:2px;">{{ user.full_name }}</h3>
            <p style="margin:0;font-size:13.5px;">Membre depuis le {{ user.created_at|date('d/m/Y') }}</p>
          </div>
        </div>

        <form method="post" action="{{ path('app_profile') }}">
          <div class="field">
            <label for="pfullname">Nom complet</label>
            <input type="text" id="pfullname" name="full_name" value="{{ user.full_name }}" required>
          </div>
          <div class="field">
            <label for="pemail">Adresse email</label>
            <input type="email" id="pemail" name="email" value="{{ user.email }}" required>
          </div>
          <button
    type="submit"
    name="save_profile"
    class="btn btn-primary">
    Enregistrer les modifications
</button>
        </form>
      </div>

      <div class="card reveal" style="max-width:680px;margin-top:20px;">
        <div class="card__head"><h3>Sécurité</h3></div>
        <!-- Not yet wired to a controller action: add a route/handler for password changes, then point this form at it. -->
        <form method="post" action="{{ path('app_profile') }}">
          <div class="form-grid">
            <div class="field">
              <label for="curpass">Mot de passe actuel</label>
              <input type="password" id="curpass" name="current_password" placeholder="••••••••">
            </div>
            <div class="field">
              <label for="newpass">Nouveau mot de passe</label>
              <input type="password" id="newpass" name="new_password" placeholder="••••••••">
            </div>
          </div>
          <button
    type="submit"
    name="change_password"
    class="btn btn-outline">
    Mettre à jour le mot de passe
</button>
        </form>
      </div>

      <div class="card reveal" style="max-width:680px;margin-top:20px;">
        <div class="card__head">
          <h3>Mots-clés surveillés</h3>
          <a href="{{ path('app_filters') }}"
   class="btn btn-outline btn-sm">
    Modifier
</a>
        </div>
        <p style="font-size:13.5px;margin-bottom:16px;">Ces mots-clés déclenchent une alerte dès qu'un bon de commande y correspond.</p>
        <div class="match-tags">
          {% for kw in keywords|default([]) %}
            <span class="match-tag">{{ kw.keyword }}</span>
          {% else %}
            <span style="font-size:13px;color:var(--ink-400);">Aucun mot-clé pour le moment — ajoutez-en depuis la page Mots-clés.</span>
          {% endfor %}
        </div>
      </div>

      <div class="card reveal" style="max-width:680px;margin-top:20px;border-color:#F3CACA;">
        <div class="card__head"><h3 style="color:var(--danger);">Zone sensible</h3></div>
        <p style="font-size:13.5px;">Se déconnecter de votre compte sur cet appareil.</p>
        <a href="/logout" class="btn btn-danger-outline">Se déconnecter</a>
      </div>
    </div>
  </div>
</div>
 <script src="/js/Scripts_more.js"></script>
</body>
</html>

{% endblock %}
