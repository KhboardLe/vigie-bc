{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tableau de bord — Vigie BC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<link href="/css/Styles_more.css" rel="stylesheet">
</head>
<body>
<div class="app">

  <aside class="sidebar">
    <a href="index.html" class="brand"><span class="brand__mark"></span> Vigie BC</a>
    <div class="sidebar__section">Navigation</div>
    <nav class="sidebar__nav">
      <a href="{{ path('dashboard') }}" class="active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
        Tableau de bord
      </a>
      <a href="{{ path('app_bc_list') }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        BC en cours
      </a>
      <a href="{{ path('app_profile') }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0116 0v1"/></svg>
        Profil
      </a>
    </nav>
    <div class="sidebar__spacer"></div>
 
    <a href="{{ path('app_logout') }}" class="logout-link" style="display:flex;align-items:center;gap:12px;padding:11px 12px;font-size:13.5px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg>
      Déconnexion
    </a>
  </aside>

  <div class="main">
    <div class="topbar">
      <div>
        <h1>Tableau de bord</h1>
        <div class="topbar__sub">Bon retour, {{ app.session.get('user_name') }} — voici votre activité récente.</div>
      </div>
      <div class="topbar__actions">
       <a href="{{ path('app_alerts') }}"
   class="icon-btn"
   title="Notifications">

    <svg width="18"
         height="18"
         viewBox="0 0 24 24"
         fill="none"
         stroke="currentColor"
         stroke-width="2">

        <path d="M22 7l-10 7L2 7"/>
        <rect x="2" y="4" width="20" height="16" rx="2"/>

    </svg>

    {% if unreadAlerts > 0 %}
        <span class="badge">{{ unreadAlerts }}</span>
    {% endif %}

</a>
 <a href="{{ path('app_filters') }}" class="btn btn-primary btn-sm">+ Filtre</a>
      </div>
    </div>

    <div class="page">
      <div class="stat-grid">
        <div class="stat-card reveal">
          <div class="stat-card__top">
            <div class="stat-card__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg></div>
            <span class="stat-card__delta delta-up">+12 cette semaine</span>
          </div>
          <div class="stat-card__value" data-count="{{ totalBC }}">0</div>
          <div class="stat-card__label">BC suivis au total</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-card__top">
            <div class="stat-card__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 7l-10 7L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg></div>
            <span class="stat-card__delta delta-up">0 aujourd'hui</span>
          </div>
          <div class="stat-card__value" data-count="{{ alertsSent }}">0</div>
          <div class="stat-card__label">Alertes envoyées</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-card__top">
            <div class="stat-card__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20l-7-7a5 5 0 117-7 5 5 0 117 7l-7 7z"/></svg></div>
            <span class="stat-card__delta delta-neutral">stable</span>
          </div>
          <div class="stat-card__value" data-count="{{ activeKeywords }}">0</div>
          <div class="stat-card__label">Mots-clés actifs</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-card__top">
            <div class="stat-card__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 2v4M16 2v4M3 10h18"/></svg></div>
            <span class="stat-card__delta delta-up">à jour</span>
          </div>
          <div class="stat-card__value">
            {{ lastScan }}
        </div>
          <div class="stat-card__label">Dernier scan il y a</div>
        </div>
      </div>

      <div class="grid-2">
        

        <div class="card reveal">
    <div class="card__head">
        <h3>Derniers BC correspondants</h3>

        <a href="#">Voir plus →</a>
    </div>

    <div class="activity">

        {% for bc in latestBCs %}

            <div class="activity-row">

                <div class="activity-row__dot"></div>

                <div style="flex:1;">

                    <b>{{ bc.reference }}</b>

                    <p>{{ bc.objet }}</p>

                    <small>{{ bc.lieu }}</small>

                </div>

                <time>{{ bc.date_limite }}</time>

            </div>
{% else %}

<div class="empty-state">

    <h3>🎉 Aucun nouveau BC cette semaine</h3>

    <p>
        Le prochain scan vérifiera automatiquement les nouveaux bons
        de commande correspondant à vos critères.
    </p>

</div>

{% endfor %}

    </div>
</div>

      </div>
    </div>
  </div>
</div>
 <script src="/js/Scripts_more.js"></script>
</body>
</html>


{% endblock %}